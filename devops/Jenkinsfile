/*
  Practica 2 - Jenkinsfile dummy (PUNTO DE PARTIDA)

  Este Jenkinsfile es intencionalmente simple. En la Practica 2 iras anadiendo
  piezas (stages, agents, funciones Groovy, Docker build, docker compose, etc.)
  hasta construir un pipeline CI/CD completo.
*/

pipeline {
  // `agent any` = el pipeline se ejecuta en cualquier nodo/agente disponible.
  agent any
  parameters {
    booleanParam(name: 'RUN_CD', defaultValue: false, description: 'Ejecutar CD')
  }
  stages {
    stage('Build CI Image') {
      steps {
        sh 'docker build -t devops/ci:latest -f devops/ci.Dockerfile .'
      }
    }
    stage('Lint') {
      agent {
        docker {
          image 'devops/ci:latest' 
        }
      }
      steps {
        sh 'make lint'
      }
    }
    stage('Test') {
      agent {
        docker {
          image 'devops/ci:latest'
        }
      }
      steps {
        sh 'mvn test'
      }
    }
    stage('CD') {
      when {
        anyOf {
          expression { return params.RUN_CD }
            branch 'develop'
            branch 'master'
          }
        }
            script {
              // =========================
              // 6.2 - Determinar entorno
              // =========================
              env.DEPLOY_ENV = (env.BRANCH_NAME == 'master') ? 'PRO' : 'DEV'

              echo "Deploying to ${env.DEPLOY_ENV}"
              echo "RUN_CD=${params.RUN_CD}, branch=${env.BRANCH_NAME}"

              def composeProject = (env.DEPLOY_ENV == 'PRO') ? 'pro' : 'dev'

              try {
                sh 'docker compose up -d'
                sh 'sleep 5'
                sh 'docker compose logs app'
              } finally {
                sh 'docker compose down --volumes'
              }
          }
        }
    stage('Info') {
      steps {
        echo "Job: ${env.JOB_NAME}"
        echo "Build: ${env.BUILD_NUMBER}"
      }
    }
  }
}
